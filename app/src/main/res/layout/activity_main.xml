<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="PIN နံပါတ် ထည့်သွင်းပါ"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewPinDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:letterSpacing="0.2"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewTitle"
        tools:text="----" />

    <GridLayout
        android:id="@+id/gridLayoutButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/textViewPinDisplay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/button1"
            android:text="1"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button2"
            android:text="2"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button3"
            android:text="3"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button4"
            android:text="4"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button5"
            android:text="5"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button6"
            android:text="6"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button7"
            android:text="7"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button8"
            android:text="8"
            style="@style/PinButtonStyle" />
        <Button
            android:id="@+id/button9"
            android:text="9"
            style="@style/PinButtonStyle" />

        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="8dp" />

        <Button
            android:id="@+id/button0"
            android:text="0"
            style="@style/PinButtonStyle" />

        <ImageButton
            android:id="@+id/buttonBackspace"
            android:src="@android:drawable/ic_input_delete"
            android:contentDescription="Backspace"
            style="@style/PinButtonStyle" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>